# Scaffold AI configuration — copy to .env and fill in real values.
# .env is gitignored; never commit real secrets.

# --- Required ---------------------------------------------------------------

# Postgres connection string (migrations run automatically on startup)
DATABASE_URL=postgres://localhost/scaffold_ai

# Numeric App ID from your GitHub App's settings page
GITHUB_APP_ID=123456

# GitHub App RSA private key: EITHER a path to the downloaded .pem ...
GITHUB_PRIVATE_KEY_PATH=./scaffold-ai.private-key.pem
# ... OR the PEM inline (takes precedence over the path if both are set)
# GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# The webhook secret you set when creating the GitHub App
GITHUB_WEBHOOK_SECRET=change-me

# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Autumn secret key
AUTUMN_SECRET_KEY=am_sk_...

# --- Optional ---------------------------------------------------------------

# BIND_ADDR=0.0.0.0:8080
# ANTHROPIC_MODEL=claude-opus-4-8
# RUST_LOG=info,scaffold=debug

# Endpoint overrides (staging/tests only)
# ANTHROPIC_BASE_URL=
# AUTUMN_BASE_URL=
# GITHUB_BASE_URL=
